<div class="container">
    <h1>Conversion History</h1>

    {{#if conversions.length}}
    <table>
        <thead>
            <tr>
                <th>From</th>
                <th>To</th>
                <th>Amount</th>
                <th>Result</th>
            </tr>
        </thead>
        <tbody>
            {{#each conversions}}
            <tr>
                <td>{{this.from}}</td>
                <td>{{this.to}}</td>
                <td>{{this.amount}}</td>
                <td>{{this.result}}</td>
                 <td>
                    <form action="/favorites" method="POST" style="display:inline;">
                     <input type="hidden" name="from" value="{{this.from}}">
                     <input type="hidden" name="to" value="{{this.to}}">
                     <input type="hidden" name="amount" value="{{this.amount}}">
                     <input type="hidden" name="result" value="{{this.result}}">
                     <button type="submit" class="favorite-btn">Favorite</button>
                    </form>

  <form action="/history/{{this._id}}/delete" method="POST" style="display:inline;">
    <button type="submit">Delete</button>
  </form>
</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
        <p>No conversions yet.</p>
    {{/if}}
    <a href="/favorites">View favorites</a>
    <a href="/" aria-label="Go back to currency converter">Back to converter</a>
</div>